{
  "name": "objectively",
  "version": "0.1.1",
  "description": "Tiny, dependency-free, strongly-typed object helpers (keys/values/entries/reduce/map/remap/rekey) that carry a documented exact-keys assumption.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoobzio/objectively.git"
  },
  "packageManager": "pnpm@10.27.0",
  "main": "./.dist/index.mjs",
  "types": "./.dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./.dist/index.d.ts",
      "import": "./.dist/index.mjs"
    }
  },
  "files": [
    ".dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "unbuild": "^3.5.0",
    "vitest": "^4.1.0"
  }
}
